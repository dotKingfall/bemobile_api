        {
          "name": "Change gateway status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "if (response.length > 0) {\r",
                  "    const gw1 = response.find(g => g.name.toLowerCase().includes('one') || g.id === 1);\r",
                  "    if (gw1) pm.collectionVariables.set(\"gateway_id\", gw1.id);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
